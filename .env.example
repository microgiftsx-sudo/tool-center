# Development Environment Variables
# Copy this file to .env.local and update the values as needed

# Next.js Environment
NODE_ENV=development
# Base URL for API
NEXT_PUBLIC_API_BASE_URL=http://localhost:3003/api/
# File URL for API
NEXT_PUBLIC_API_FILE_URL=http://localhost:3003/
# Enable remote sync for extractor settings/recent files
NEXT_PUBLIC_ENABLE_REMOTE_EXCEL_SYNC=false
# Enable remote sync for activity feed
NEXT_PUBLIC_ENABLE_REMOTE_ACTIVITY_SYNC=false

# PostgreSQL connection used by Next.js API routes
# Example: postgresql://postgres:postgres@localhost:5432/tools_hub
DATABASE_URL=

# Optional: force mock saved selection in API response
USE_MOCK_EXTRACTED_SELECTION=false

