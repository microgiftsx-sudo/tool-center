# Development Environment Variables
# Copy this file to .env.local and update the values as needed

# Next.js Environment
NODE_ENV=development
# Base URL for generic API integrations (optional)
NEXT_PUBLIC_API_BASE_URL=
# Base URL for auth API when using external backend (e.g. Nest API on 3001)
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:3001
# File URL for API (if used by media/file features)
NEXT_PUBLIC_API_FILE_URL=
# Enable remote sync for extractor settings/recent files
NEXT_PUBLIC_ENABLE_REMOTE_EXCEL_SYNC=false
# Enable remote sync for activity feed
NEXT_PUBLIC_ENABLE_REMOTE_ACTIVITY_SYNC=false
# Use external auth backend when true; local /api/auth when false.
# Endpoints mapped in remote mode:
# - /auth/login
# - /auth/change-password
# - /auth/me
# - /users
NEXT_PUBLIC_ENABLE_REMOTE_AUTH=false

# PostgreSQL connection used by Next.js API routes
# Example: postgresql://postgres:postgres@localhost:5432/tools_hub
DATABASE_URL=

# Force maintenance mode for non-admin users
# When true, admin toggle cannot disable maintenance until this is false
MAINTENANCE_MODE=false

